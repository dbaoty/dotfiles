! special
URxvt.background: #EFF1F5
URxvt.foreground: #4C4F69
URxvt.cursorColor: #DC8A78

! black
URxvt.color0: #5C5F77
URxvt.color8: #6C6F85

! red
URxvt.color1: #D20F39
URxvt.color9: #D20F39

! green
URxvt.color2: #40A02B
URxvt.color10: #40A02B

! yellow
URxvt.color3: #DF8E1D
URxvt.color11: #DF8E1D

! blue
URxvt.color4: #1E66F5
URxvt.color12: #1E66F5

! magenta
URxvt.color5: #EA76CB
URxvt.color13: #EA76CB

! cyan
URxvt.color6: #179299
URxvt.color14: #179299

! white
URxvt.color7: #ACB0BE
URxvt.color15: #BCC0CC

*.font:			xft:Iosevka:style=Regular:size=9
*.boldFont:		xft:Iosevka:style=Bold:size=9
*.italicFont:		xft:Iosevka:style=Italic:size=9
*.boldItalicFont:	xft:Iosevka:style=Bold Italic:size=9

*.cursorUnderline:	true
*.cursorBlink:		true

URxvt.internalBorder: 12
URxvt.scrollBar: false
